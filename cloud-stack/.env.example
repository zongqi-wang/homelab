# cloud-stack environment variables
# Copy this to .env and fill in real values before deploying.

LAN_HOST=changeme

# Nextcloud / MariaDB
MYSQL_ROOT_PASSWORD=changeme
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud

# Paperless-ngx / Postgres
POSTGRES_PASSWORD=changeme
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme
PAPERLESS_SECRET_KEY=changeme

# AutoKuma default notification list (shared with arr-stack AutoKuma service)
AUTOKUMA_DEFAULT_NOTIFICATION_NAME_LIST='["Homelab Alerts"]'

# gitea environment variables
# Copy this to .env and fill in real values before deploying.

LAN_HOST=changeme
AUTOKUMA_DEFAULT_NOTIFICATION_NAME_LIST='["Homelab Alerts"]'

# Gitea admin (created on first init)
GITEA_ADMIN_USER=changeme
GITEA_ADMIN_PASSWORD=changeme
GITEA_ADMIN_EMAIL=changeme@example.com

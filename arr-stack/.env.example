# arr-stack environment variables
# Copy this to .env and fill in real values before deploying.

PUID=99
PGID=100
TZ=America/Los_Angeles
UMASK=002
LAN_HOST=changeme
LAN_SUBNET=192.168.1.0/24

# VPN (Gluetun + qBittorrent) -- custom WireGuard provider
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=changeme
WIREGUARD_ADDRESSES=10.2.0.2/32
WIREGUARD_PUBLIC_KEY=changeme
VPN_ENDPOINT_IP=changeme
VPN_ENDPOINT_PORT=51820
DNS_ADDRESS=10.2.0.1

# Immich
IMMICH_VERSION=release
UPLOAD_LOCATION=/mnt/user/data/photos/library
DB_DATA_LOCATION=/mnt/user/appdata/immich/postgres
MODEL_CACHE_LOCATION=/mnt/user/appdata/immich/model-cache
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_DATABASE_NAME=immich

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# Prometheus Alertmanager -> Discord
PROMETHEUS_DISCORD_WEBHOOK=changeme

# AutoKuma -> Uptime Kuma API auth
AUTOKUMA_KUMA_URL=http://uptime-kuma:3001
AUTOKUMA_KUMA_USERNAME=admin
AUTOKUMA_KUMA_PASSWORD=changeme
AUTOKUMA_DEFAULT_NOTIFICATION_NAME_LIST='["Homelab Alerts"]'
AUTOKUMA_ALERT_PROVIDER_ACTIVE=false
AUTOKUMA_ALERT_PROVIDER_CONFIG_JSON='{"type":"webhook","webhookURL":"http://127.0.0.1:65535"}'

# Uptime Kuma status page bootstrap (Phase 5)
UPTIME_KUMA_STATUS_PAGE_SLUG=default
UPTIME_KUMA_STATUS_PAGE_TITLE="Homelab Status"
UPTIME_KUMA_STATUS_PAGE_DESCRIPTION="Automated status page"
UPTIME_KUMA_STATUS_PAGE_PUBLISHED=true
UPTIME_KUMA_STATUS_PAGE_GROUP_NAME=Services
UPTIME_KUMA_STATUS_PAGE_DOMAIN_LIST_JSON='[]'

# Homepage widget keys (passed as HOMEPAGE_VAR_* env vars)
HOMEPAGE_VAR_JELLYFIN_KEY=changeme
HOMEPAGE_VAR_JELLYSEERR_KEY=changeme
HOMEPAGE_VAR_PROWLARR_KEY=changeme
HOMEPAGE_VAR_SONARR_KEY=changeme
HOMEPAGE_VAR_RADARR_KEY=changeme
HOMEPAGE_VAR_LIDARR_KEY=changeme
HOMEPAGE_VAR_BAZARR_KEY=changeme
HOMEPAGE_VAR_QBIT_USERNAME=admin
HOMEPAGE_VAR_QBIT_PASSWORD=changeme
HOMEPAGE_VAR_SABNZBD_KEY=changeme
HOMEPAGE_VAR_CF_ACCOUNT_ID=changeme
HOMEPAGE_VAR_CF_TUNNEL_ID=changeme
HOMEPAGE_VAR_CF_TUNNEL_TOKEN=changeme
HOMEPAGE_VAR_NEXTCLOUD_KEY=changeme
HOMEPAGE_VAR_PAPERLESS_KEY=changeme
HOMEPAGE_VAR_IMMICH_KEY=changeme
HOMEPAGE_VAR_GRAFANA_PASSWORD=changeme
HOMEPAGE_VAR_GITEA_KEY=changeme
HOMEPAGE_VAR_UPTIMEKUMA_SLUG=default
HOMEPAGE_VAR_WEATHER_LABEL=Home
HOMEPAGE_VAR_WEATHER_LAT=49.2827
HOMEPAGE_VAR_WEATHER_LON=-123.1207
HOMEPAGE_VAR_WEATHER_TZ=America/Vancouver
HOMEPAGE_VAR_WEATHER_UNITS=metric
